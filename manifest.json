{
  "manifest_version": 3,
  "name": "Rapid Reporter",
  "version": "0.0.10",
  "description": "One click -> a complete Redmine bug: screenshot, DOM, console, network.",

  "permissions": ["activeTab", "storage", "scripting"],

  "host_permissions": ["https://tracker.rapiddata.com/*"],

  "options_page": "options.html",

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["capture.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Rapid Reporter"
  }
}
